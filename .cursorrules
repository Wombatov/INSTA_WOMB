## State Management Pattern

```typescript
// Zustand store — шаблон
import { create } from 'zustand';
import { persist, createJSONStorage } from 'zustand/middleware';
import { storage } from '@/utils/storage'; // MMKV wrapper

interface PostsState {
  posts: Post[];
  // actions always end with verb
  addPost: (content: string) => void;
  updatePost: (id: string, data: Partial<Post>) => void;
  deletePost: (id: string) => void;
}

export const usePostsStore = create<PostsState>()(
  persist(
    (set, get) => ({
      posts: [],
      addPost: (content) => set((state) => ({
        posts: [createPost(content), ...state.posts]
      })),
      // ...
    }),
    {
      name: 'posts-storage',
      storage: createJSONStorage(() => storage),
    }
  )
);
```

---

## Navigation Pattern (Expo Router)

```typescript
// Переход на экран редактирования
import { router } from 'expo-router';
router.push(`/post/${post.id}`);

// Открытие модального превью
router.push('/post/preview');

// Передача данных через params (только примитивы!)
router.push({ pathname: '/post/preview', params: { postId: post.id } });

// В экране-получателе:
import { useLocalSearchParams } from 'expo-router';
const { postId } = useLocalSearchParams<{ postId: string }>();
```

---

## Component Template

```typescript
// components/example/ExampleComponent.tsx
import React, { memo } from 'react';
import { View, Pressable } from 'react-native';
import Animated, { useSharedValue, useAnimatedStyle, withSpring } from 'react-native-reanimated';
import { AppText } from '@/components/ui/AppText';

interface ExampleComponentProps {
  title: string;
  onPress: () => void;
  disabled?: boolean;
}

export const ExampleComponent = memo<ExampleComponentProps>(({ 
  title, 
  onPress, 
  disabled = false 
}) => {
  const scale = useSharedValue(1);
  
  const animatedStyle = useAnimatedStyle(() => ({
    transform: [{ scale: scale.value }]
  }));

  return (
    <Animated.View style={animatedStyle} className="...NativeWind classes...">
      <Pressable
        onPress={onPress}
        onPressIn={() => { scale.value = withSpring(0.97); }}
        onPressOut={() => { scale.value = withSpring(1); }}
        disabled={disabled}
        accessibilityRole="button"
        accessibilityLabel={title}
        className="min-h-12 min-w-12 ..."
      >
        <AppText>{title}</AppText>
      </Pressable>
    </Animated.View>
  );
});

ExampleComponent.displayName = 'ExampleComponent';
```

